<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F3F3F3"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:src="@drawable/ic_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            app:tint="#000"
            android:contentDescription="@string/back_button"/>

        <!-- Title beside back -->
        <TextView
            android:text="ನಾನು ಕೆಲಸಗಾರ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Right text -->
        <TextView
            android:id="@+id/txtEditProfile"
            android:text="ಪ್ರೊಫೈಲ್ ತಿದ್ದಿ"
            android:textSize="12sp"
            android:textColor="#6D6D6D"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
    <!-- Spacer pushes cards to center -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

    <!-- BIG GREY CARD -->
    <LinearLayout
        android:id="@+id/availabilityCard"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_grey_card"
        android:padding="24dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <TextView
            android:id="@+id/txtAvailabilityStatus"
            android:text="@string/availability_off"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#5A5A5A"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAvailability"
            android:layout_width="60dp"
            android:layout_height="34dp"
            android:showText="false"/>

        <TextView
            android:id="@+id/toggleHint"
            android:text="@string/availability_hint"
            android:textSize="12sp"
            android:textColor="#7A7A7A"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- BOTTOM CARDS -->
    <LinearLayout
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- LEFT CARD -->
        <LinearLayout
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_white_card"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="120dp">

            <TextView
                android:id="@+id/txtWorkCount"
                android:text="0"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="ಕೆಲಸಗಳು"
                android:textSize="12sp"
                android:textColor="#6D6D6D"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- RIGHT CARD -->
        <LinearLayout
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_white_card"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="120dp">

            <TextView
                android:id="@+id/txtWorkType"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="ಪ್ರದೇಶ"
                android:textSize="12sp"
                android:textColor="#6D6D6D"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>