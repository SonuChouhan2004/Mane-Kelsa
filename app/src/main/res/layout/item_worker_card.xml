<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    android:id="@+id/cardRoot"
    app:cardElevation="4dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 🔹 Top Row: Image + Availability + Name/Work -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Profile image with availability dot -->
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp">

                <ImageView
                    android:id="@+id/imgWorker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/bg_image_border"
                    android:contentDescription="@string/worker_image" />

                <View
                    android:id="@+id/availabilityDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_availability_dot"
                    android:layout_margin="2dp" />
            </FrameLayout>

            <!-- Name + Work type -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/txtName"
                    android:text="ಲಕ್ಷ್ಮೀ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/txtWorkType"
                    android:text="ಮನೆಮದ್ದು / ಕ್ಲೀನಿಂಗ್"
                    android:textSize="14sp"
                    android:textColor="#4E4A2B"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Availability badge -->
            <TextView
                android:id="@+id/txtAvailable"
                android:text="ಇಂದು ಲಭ್ಯವಿದೆ"
                android:textSize="12sp"
                android:textColor="#008000"
                android:background="@drawable/bg_available"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_gravity="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 🔹 Wage + Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/txtRate"
                android:text="ದಿನದ ದರ: ರೂ. 350"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtLocation"
                android:text="ಪ್ರದೇಶ: ಬಸವನಗುಡಿ"
                android:textSize="14sp"
                android:textColor="#4E4A2B"
                android:gravity="end"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 🔹 Likes + Call button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnLike"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_thumb_up"
                    android:contentDescription="@string/like_icon"
                    app:tint="#4E4A2B" />

                <TextView
                    android:id="@+id/txtLikes"
                    android:text="44"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btnCall"
                android:text="ಕರೆ ಮಾಡಿ"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4E4A2B"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingHorizontal="16dp"
                android:drawableLeft="@drawable/ic_call"
                android:drawablePadding="8dp"
                android:layout_gravity="end"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
