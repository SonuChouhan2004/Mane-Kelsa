<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9F8F3">

    <!-- 🔹 Top bar with back arrow and Kannada title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back_button" />

        <TextView
            android:id="@+id/txtHeader"
            android:text="ನಾನು ಮಾಲೀಕ"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginStart="12dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_search"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:layout_margin="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/icSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/search_icon"
            android:layout_marginEnd="8dp"
            app:tint="#9E9E9E" />

        <EditText
            android:id="@+id/editSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ನಿಮ್ಮ ಪ್ರದೇಶವನ್ನು ಹುಡುಕಿ..."
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:singleLine="true" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/horizontalScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                app:iconTint="@color/chip_icon_tint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent"
                android:id="@+id/btnAll"
                android:text="ಎಲ್ಲಾ"
                android:textSize="14sp"
                android:textColor="#4E4A2B"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                app:icon="@drawable/ic_location"/>

            <com.google.android.material.button.MaterialButton
                app:iconTint="@color/chip_icon_tint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent"
                android:id="@+id/btnBasavanagudi"
                android:text="ಬಸವನಗುಡಿ"
                android:textSize="14sp"
                android:textColor="#4E4A2B"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp"
                app:icon="@drawable/ic_location"
                android:paddingVertical="6dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content" />

            <com.google.android.material.button.MaterialButton
                app:iconTint="@color/chip_icon_tint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_location"
                app:rippleColor="@android:color/transparent"
                android:id="@+id/btnJayanagar"
                android:text="ಜಯನಗರ"
                android:textSize="14sp"
                android:textColor="#4E4A2B"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content" />

            <com.google.android.material.button.MaterialButton
                app:iconTint="@color/chip_icon_tint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:backgroundTint="@null"
                app:rippleColor="@android:color/transparent"
                app:icon="@drawable/ic_location"
                android:id="@+id/btnRajajinagar"
                android:text="ರಾಜಾಜಿನಗರ"
                android:textSize="14sp"
                android:textColor="#4E4A2B"
                android:background="@drawable/bg_chip_unselected"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content" />

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnScrollLeft"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="@string/scroll_left"
            app:tint="#4E4A2B" />

        <SeekBar
            android:id="@+id/scrollIndicator"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:progressDrawable="@drawable/bg_scrollbar"
            android:thumb="@drawable/bg_scroll_thumb"
            android:enabled="false"
            android:padding="0dp" />

        <ImageButton
            android:id="@+id/btnScrollRight"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_right"
            android:contentDescription="@string/scroll_right"
            app:tint="#4E4A2B" />
    </LinearLayout>

    <!-- 🔹 RecyclerView for worker cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />
</LinearLayout>
